# Local and cloud environment variables for SecureDesk Tracker
# Copy this file to .env and fill in real values.

SECRET_KEY=replace-with-a-strong-secret
DEBUG=False
ALLOWED_HOSTS=your-app.onrender.com
CSRF_TRUSTED_ORIGINS=https://your-app.onrender.com

# Optional database URL for cloud providers like Render
DATABASE_URL=postgres://user:password@host:port/dbname

# Optional Cloudinary values if using Cloudinary storage
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Optional Twilio values for SMS alerts
TWILIO_ACCOUNT_SID=your-twilio-sid
TWILIO_AUTH_TOKEN=your-twilio-token
TWILIO_FROM_NUMBER=your-twilio-from-number
TWILIO_SMS_RECIPIENTS=+1234567890
